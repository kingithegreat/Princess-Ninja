# Copy to android/keystore.properties (untracked — see .gitignore) to sign
# release builds locally. Generate a keystore first, from the android/
# directory (so it lands next to this file, both ignored by git):
#
#   cd android
#   keytool -genkeypair -v -keystore princess-ninja-release.jks \
#     -alias princess-ninja -keyalg RSA -keysize 2048 -validity 10000
#
# In CI, keystore.properties + the .jks are written from secrets at build
# time instead of committed — see .github/workflows/android.yml.

storeFile=princess-ninja-release.jks
storePassword=CHANGE_ME
keyAlias=princess-ninja
keyPassword=CHANGE_ME
